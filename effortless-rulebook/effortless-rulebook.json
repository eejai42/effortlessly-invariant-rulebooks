  "Approvals": {
    "Description": "Table: Approvals",
    "schema": [
      {
        "name": "ApprovalId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \u0022 \u0022, \u0022-\u0022)"
      },
      {
        "name": "DisplayName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "WorkflowSteps",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Back-reference to workflow steps that use this approval gate. Enables finding all steps requiring this specific gate.",
        "RelatedTo": "WorkflowSteps"
      },
      {
        "name": "EscalationThresholdHours",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "Integer number of hours that may elapse on a pending gate before the ntwf:delegatesTo chain activates. Maps to ntwf:escalationThresholdHours. Domain applies only to ApprovalGate individuals."
      },
      {
        "name": "Workflow_from_WorkflowSteps",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(WorkflowSteps!{{Workflow}}, MATCH(Approvals!{{WorkflowSteps}}, WorkflowSteps!{{WorkflowStepId}}, 0))"
      },
      {
        "name": "Assigned_Role_from_WorkflowSteps",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(WorkflowSteps!{{AssignedRole}}, MATCH(Approvals!{{WorkflowSteps}}, WorkflowSteps!{{WorkflowStepId}}, 0))"
      },
      {
        "name": "Sequence_Position_from_WorkflowSteps",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(WorkflowSteps!{{SequencePosition}}, MATCH(Approvals!{{WorkflowSteps}}, WorkflowSteps!{{WorkflowStepId}}, 0))"
      },
      {
        "name": "Requires_Human_Approval_from_WorkflowSteps",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(WorkflowSteps!{{RequiresHumanApproval}}, MATCH(Approvals!{{WorkflowSteps}}, WorkflowSteps!{{WorkflowStepId}}, 0))"
      }
    ],
