{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Jessica Talisman - ADVANCED Ontology Parts 1-3",
  "Description": "Rulebook generated from Airtable base \u0027Jessica Talisman - ADVANCED Ontology Parts 1-3\u0027.",
  "Workflows": {
    "Description": "Table: Workflows",
    "schema": [
      {
        "name": "WorkflowId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Short machine-friendly name for the workflow. Used for programmatic reference and URL slug generation.",
        "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \u0022 \u0022, \u0022-\u0022)"
      },
      {
        "name": "DisplayName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Title",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Human-readable title of the workflow. Maps to dct:title from Dublin Core. Example: \u0027Production Deployment Workflow\u0027, \u0027Employee Onboarding\u0027."
      },
      {
        "name": "Description",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Detailed description of the workflow\u0027s purpose and scope. Maps to dct:description from Dublin Core. Should explain what business goal the workflow achieves."
      },
      {
        "name": "Identifier",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "External system identifier for cross-referencing. Maps to dct:identifier from Dublin Core. This is the join key back to document management systems, ticket systems, or other operational systems."
      },
      {
        "name": "Modified",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true,
        "Description": "Last modification timestamp. Maps to dct:modified from Dublin Core. Critical for answering CQ5: \u0027Which workflows haven\u0027t been reviewed or updated in twelve months?\u0027"
      },
      {
        "name": "WorkflowSteps",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Reference to workflow steps. Represents the ntwf:hasStep relationship linking workflows to their constituent steps.",
        "RelatedTo": "WorkflowSteps"
      },
      {
        "name": "CountOfSteps",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Calculated count of workflow steps in this workflow. Useful for workflow complexity analysis and reporting.",
        "formula": "=COUNTIFS(WorkflowSteps!{{Workflow}}, Workflows!{{WorkflowId}})"
      },
      {
        "name": "HasMoreThan1Step",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "={{CountOfSteps}} \u003E 1"
      }
    ],
    "data": [
      {
        "WorkflowId": "production-deployment",
        "Name": "production-deployment",
        "Title": "Production Deployment Workflow",
        "Description": "End-to-end workflow for deploying software releases to production, including risk analysis, legal clearance, and executive approval gates.",
        "Identifier": "ss:workflow-production-deployment",
        "Modified": "2026-01-15",
        "WorkflowSteps": "risk-analysis, legal-clearance, release-approval-gate, deployment-execution, post-deployment-review",
        "CountOfSteps": 5,
        "DisplayName": "Production Deployment",
        "HasMoreThan1Step": true
      }
    ]
  },
  "WorkflowSteps": {
    "Description": "Table: WorkflowSteps",
    "schema": [
      {
        "name": "WorkflowStepId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \u0022 \u0022, \u0022-\u0022)"
      },
      {
        "name": "DisplayName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Workflow",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Foreign key to the parent workflow. Represents the inverse of ntwf:hasStep, enabling navigation from step to its containing workflow (ntwf:isStepOf).",
        "RelatedTo": "Workflows"
      },
      {
        "name": "SequencePosition",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "Integer ordinal position of the step within its workflow. Maps to ntwf:sequencePosition, declared as owl:FunctionalProperty (each step has exactly one position). Enables positional queries."
      },
      {
        "name": "AssignedRole",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Foreign key to the Role responsible for executing this step. Maps to ntwf:assignedRole. Critical for implementing Heuristic 2 (role-agent separation): steps point to roles, not directly to agents.",
        "RelatedTo": "Roles"
      },
      {
        "name": "RequiresHumanApproval",
        "datatype": "boolean",
        "type": "raw",
        "nullable": true,
        "Description": "Boolean flag indicating whether a human agent must fill the assigned role. Maps to ntwf:requiresHumanApproval. Enables answering CQ3: \u0027Which steps require human decisions vs. AI execution?\u0027"
      },
      {
        "name": "ApprovalGate",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Foreign key to ApprovalGate if this step is a decision checkpoint. When populated, indicates this step blocks workflow execution until explicit authorization is given.",
        "RelatedTo": "Approvals"
      },
      {
        "name": "PrecededBySteps",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Reference to steps that must complete before this step can execute. Part of the ntwf:precedesStep transitive ordering relationship.",
        "RelatedTo": "PrecedesSteps"
      },
      {
        "name": "ExecutionActorType",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{AssignedRoleDepartment}} = \u0022HumanAgent\u0022, \u0022HumanAgent\u0022, IF({{AssignedRoleDepartment}} = \u0022AIAgent\u0022, \u0022AIAgent\u0022, IF({{AssignedRoleDepartment}} = \u0022AutomatedPipeline\u0022, \u0022AutomatedPipeline\u0022, BLANK())))"
      },
      {
        "name": "AssignedRoleDepartment",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Roles!{{OwnedBy}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))"
      },
      {
        "name": "ApprovalGateEscalationThresholdHours",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Approvals!{{EscalationThresholdHours}}, MATCH(WorkflowSteps!{{ApprovalGate}}, Approvals!{{ApprovalId}}, 0))"
      },
      {
        "name": "StepTransitions_From_Step",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "StepTransitions"
      },
      {
        "name": "StepTransitions_To_Step",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "StepTransitions"
      },
      {
        "name": "WorkflowArtifacts",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "WorkflowArtifacts"
      }
    ],
