        "PythagoreanTheoremHolds": true,
        "IsRectangle": false
      },
      {
        "ShapeId": "shape2",
        "Name": "Shape2",
        "Sides": "shape2-side-a, shape2-side-b, shape2-side-c, shape2-side-d",
        "HowManySides": 4,
        "SumOfInternalAngles": 360,
        "MaxAngle": 90,
        "HypotenuseLengthSquared": 0,
        "NonHypotenuseSidesSquared": 0,
        "IsRectangle": true,
        "IsTriangle": false,
        "IsRightTriangle": false,
        "PythagoreanTheoremHolds": false
      }
    ]
  },
  "Sides": {
    "Description": "Table: Sides",
    "schema": [
      {
        "name": "SideId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Shape}} \u0026 \u0022-Side-\u0022 \u0026 {{Label}}"
      },
      {
        "name": "ShapeSides",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Shapes!{{HowManySides}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
      },
      {
        "name": "Label",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Label for this edge"
      },
      {
        "name": "IsRectangle",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Shapes!{{IsRectangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
      },
      {
        "name": "IsTriangle",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Shapes!{{IsTriangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
      },
      {
        "name": "IsRightTriangle",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "Description": "Is this the Hypotenuse of a Right Angle Triangle?",
        "formula": "=INDEX(Shapes!{{IsRightTriangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
      },
      {
        "name": "IsHypotenuse",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "Is this the Hypotenuse of a Right Angle Triangle?",
        "formula": "=AND(\r\n  {{IsTriangle}},\r\n  {{Length}} \u003E {{PreviousSideLength}},\r\n  {{Length}} \u003E {{NextLength}}\r\n)"
      },
      {
        "name": "StatusOfTheorem",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Invalid if it is a Triangle with Mismatchd Edge Lengths and Angles.",
        "formula": "=IF({{IsTriangle}}, \n  IF(AND({{IsRightTriangle}}, NOT({{PythagoreanTheoremHolds}})), \n    \u0022PYTHAGOREAN THEOREM FALSIFIED!\u0022, \n    \u0022Pythagorean Theorem Holds (obviously).\u0022\n  ),\n  \u0022NA\u0022\n)"
      },
      {
        "name": "PythagoreanTheoremHolds",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "Description": "Does the Pythagorean Theorem Hold?",
        "formula": "=INDEX(Shapes!{{PythagoreanTheoremHolds}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
      },
      {
        "name": "LengthSquared",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Length}} * {{Length}}"
      },
      {
        "name": "HypotenuseLengthSquared",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{IsHypotenuse}}, {{LengthSquared}})"
      },
      {
        "name": "NonHypotenuseLengthSquared",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF(AND(NOT({{IsHypotenuse}}), {{IsTriangle}}), {{LengthSquared}})"
      },
      {
        "name": "PreviousSideLength",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "Description": "Previous Edge Length",
        "formula": "=INDEX(Sides!{{Length}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
      },
      {
        "name": "Length",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "Length"
      },
      {
        "name": "NextLength",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "Description": "Next Edge Length",
        "formula": "=INDEX(Sides!{{Length}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
      },
      {
        "name": "PreviousAngle",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "Description": "Previous Angle",
        "formula": "=INDEX(Sides!{{Angle}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
      },
      {
        "name": "Angle",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "Internal angles for the shapes"
      },
      {
        "name": "NextAngle",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "Description": "Next Angle",
        "formula": "=INDEX(Sides!{{Angle}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
      },
      {
        "name": "PreviousSide",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Previous Edge",
        "RelatedTo": "Sides"
      },
      {
        "name": "NextSide",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Next Edge",
        "RelatedTo": "Sides"
      },
      {
        "name": "Shape",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Shape",
        "RelatedTo": "Shapes"
      },
      {
        "name": "PreviousLabel",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Sides!{{Label}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
      },
      {
        "name": "NextLabel",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Sides!{{Label}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
      }
    ],
