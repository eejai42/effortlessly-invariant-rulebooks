  "Departments": {
    "Description": "Table: Departments",
    "schema": [
      {
        "name": "DepartmentId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Human-readable display name of the department. Should match organizational terminology for stakeholder communication.",
        "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \u0022 \u0022, \u0022-\u0022)"
      },
      {
        "name": "Title",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Human-readable display name of the department. Should match organizational terminology for stakeholder communication."
      },
      {
        "name": "DisplayName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Machine-friendly name for programmatic reference."
      },
      {
        "name": "Roles",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "Description": "Back-reference to roles owned by this department. Inverse of Roles.OwnedBy.",
        "RelatedTo": "Roles"
      },
      {
        "name": "All_Owned_Roles",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Roles!{{DisplayName}}, MATCH(Departments!{{Roles}}, Roles!{{RoleId}}, 0))"
      },
      {
        "name": "All_Related_Workflow_Steps",
        "datatype": "string",
