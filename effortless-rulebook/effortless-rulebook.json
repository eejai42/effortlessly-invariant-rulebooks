  "Shapes": {
    "Description": "Table: Shapes",
    "schema": [
      {
        "name": "ShapeId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Sides",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Sides"
      },
      {
        "name": "HowManySides",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Sides!{{Shape}}, Shapes!{{ShapeId}})"
      },
      {
        "name": "IsRectangle",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=AND({{HowManySides}}=4)"
      },
      {
        "name": "IsTriangle",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=AND({{SumOfInternalAngles}}=180, {{HowManySides}}=3)"
      },
      {
        "name": "IsRightTriangle",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=AND({{IsTriangle}}, {{MaxAngle}} = 90)"
      },
      {
        "name": "SumOfInternalAngles",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Sides!{{Angle}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
      },
      {
        "name": "MaxAngle",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=MAXIFS(Sides!{{Angle}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
      },
      {
        "name": "HypotenuseLengthSquared",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Sides!{{HypotenuseLengthSquared}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
      },
      {
        "name": "NonHypotenuseSidesSquared",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Sides!{{NonHypotenuseLengthSquared}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
      },
      {
        "name": "PythagoreanTheoremHolds",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=AND(\r\n  {{IsRightTriangle}},  \r\n  {{HypotenuseLengthSquared}} = {{NonHypotenuseSidesSquared}}\r\n)"
      }
    ],
    "data": [
      {
        "ShapeId": "shape1",
        "Name": "Shape1",
        "Sides": "shape1-side-a, shape1-side-b, shape1-side-c",
        "HowManySides": 3,
