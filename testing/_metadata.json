{
  "workflows": {
    "primary_key": "workflow_id",
    "computed_columns": [
      "name",
      "count_of_steps",
      "has_more_than1_step"
    ],
    "record_count": 1
  },
  "workflow_steps": {
    "primary_key": "workflow_step_id",
    "computed_columns": [
      "name",
      "execution_actor_type"
    ],
    "record_count": 5
  },
  "approvals": {
    "primary_key": "approval_id",
    "computed_columns": [
      "name"
    ],
    "record_count": 1
  },
  "precedes_steps": {
    "primary_key": "precedes_step_id",
    "computed_columns": [
      "display_name"
    ],
    "record_count": 5
  },
  "roles": {
    "primary_key": "role_id",
    "computed_columns": [
      "name"
    ],
    "record_count": 6
  },
  "departments": {
    "primary_key": "department_id",
    "computed_columns": [
      "name"
    ],
    "record_count": 2
  }
}