# =============================================================================
# ERB Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.
#
# ALL KEYS ARE OPTIONAL - The system uses cached data when keys are not set.
# =============================================================================

# =============================================================================
# AIRTABLE API KEY
# =============================================================================
# Used for: Pulling fresh data from Airtable bases
# Without it: Uses cached rulebook from bases/<name>/effortless-rulebook.json
#
# Get your key at: https://airtable.com/create/tokens
# Required scopes: data.records:read, schema.bases:read
#
# AIRTABLE_API_KEY=pat...

# =============================================================================
# OPENAI API KEY
# =============================================================================
# Used for: English substrate LLM-based specification generation
# Without it: Uses cached specification from bases/<name>/english-specification.md
#
# Get your key at: https://platform.openai.com/api-keys
#
# OPENAI_API_KEY=sk-...

# =============================================================================
# ANTHROPIC API KEY (alternative to OpenAI)
# =============================================================================
# Used for: English substrate with Claude models (alternative to OpenAI)
# Without it: Falls back to OpenAI, or cached specification
#
# Get your key at: https://console.anthropic.com/
#
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# LLM CONFIGURATION (optional)
# =============================================================================
# LLM_PROVIDER: Which LLM provider to use (openai or anthropic)
# LLM_TIER: Model tier - smart (best), medium (balanced), cheap (fast)
#
# LLM_PROVIDER=openai
# LLM_TIER=medium

# =============================================================================
# QUICK START
# =============================================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Add your keys (at minimum, OPENAI_API_KEY for full functionality)
#
# 3. Run the Docker setup:
#    ./run-in-docker.sh start
#
# Or use the interactive setup wizard:
#    ./run-in-docker.sh setup
# =============================================================================
