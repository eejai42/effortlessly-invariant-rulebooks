    "Shapes": {
      "attributes": [
        {
          "name": "ShapeId",
          "type": "string"
        },
        {
          "name": "Name",
          "type": "string"
        },
        {
          "name": "Sides",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "HowManySides",
          "type": "integer",
          "formula": "=COUNTIFS(Sides!{{Shape}}, Shapes!{{ShapeId}})"
        },
        {
          "name": "IsRectangle",
          "type": "boolean",
          "formula": "=AND({{HowManySides}}=4)"
        },
        {
          "name": "IsTriangle",
          "type": "boolean",
          "formula": "=AND({{SumOfInternalAngles}}=180, {{HowManySides}}=3)"
        },
        {
          "name": "IsRightTriangle",
          "type": "boolean",
          "formula": "=AND({{IsTriangle}}, {{MaxAngle}} = 90)"
        },
        {
          "name": "SumOfInternalAngles",
          "type": "number",
          "formula": "=SUMIFS(Sides!{{Angle}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
        },
        {
          "name": "MaxAngle",
          "type": "number",
          "formula": "=MAXIFS(Sides!{{Angle}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
        },
        {
          "name": "HypotenuseLengthSquared",
          "type": "number",
          "formula": "=SUMIFS(Sides!{{HypotenuseLengthSquared}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
        },
        {
          "name": "NonHypotenuseSidesSquared",
          "type": "number",
          "formula": "=SUMIFS(Sides!{{NonHypotenuseLengthSquared}}, Sides!{{Shape}}, Shapes!{{ShapeId}})"
        },
        {
          "name": "PythagoreanTheoremHolds",
          "type": "boolean",
          "formula": "=AND(\r\n  {{IsRightTriangle}},  \r\n  {{HypotenuseLengthSquared}} = {{NonHypotenuseSidesSquared}}\r\n)"
        }
      ]
    },
    "Sides": {
      "attributes": [
        {
          "name": "SideId",
          "type": "string"
        },
        {
          "name": "Label",
          "type": "string"
        },
        {
          "name": "Length",
          "type": "integer"
        },
        {
          "name": "Angle",
          "type": "integer"
        },
        {
          "name": "PreviousSide",
          "type": "string"
        },
        {
          "name": "NextSide",
          "type": "string"
        },
        {
          "name": "Shape",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "Name",
          "type": "string",
          "formula": "={{Shape}} & \"-Side-\" & {{Label}}"
        },
        {
          "name": "ShapeSides",
          "type": "integer",
          "formula": "=INDEX(Shapes!{{HowManySides}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
        },
        {
          "name": "IsRectangle",
          "type": "boolean",
          "formula": "=INDEX(Shapes!{{IsRectangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
        },
        {
          "name": "IsTriangle",
          "type": "boolean",
          "formula": "=INDEX(Shapes!{{IsTriangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
        },
        {
          "name": "IsRightTriangle",
          "type": "boolean",
          "formula": "=INDEX(Shapes!{{IsRightTriangle}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
        },
        {
          "name": "IsHypotenuse",
          "type": "boolean",
          "formula": "=AND(\r\n  {{IsTriangle}},\r\n  {{Length}} > {{PreviousSideLength}},\r\n  {{Length}} > {{NextLength}}\r\n)"
        },
        {
          "name": "StatusOfTheorem",
          "type": "string",
          "formula": "=IF({{IsTriangle}}, \n  IF(AND({{IsRightTriangle}}, NOT({{PythagoreanTheoremHolds}})), \n    \"PYTHAGOREAN THEOREM FALSIFIED!\", \n    \"Pythagorean Theorem Holds (obviously).\"\n  ),\n  \"NA\"\n)"
        },
        {
          "name": "PythagoreanTheoremHolds",
          "type": "boolean",
          "formula": "=INDEX(Shapes!{{PythagoreanTheoremHolds}}, MATCH(Sides!{{Shape}}, Shapes!{{ShapeId}}, 0))"
        },
        {
          "name": "LengthSquared",
          "type": "integer",
          "formula": "={{Length}} * {{Length}}"
        },
        {
          "name": "HypotenuseLengthSquared",
          "type": "integer",
          "formula": "=IF({{IsHypotenuse}}, {{LengthSquared}})"
        },
        {
          "name": "NonHypotenuseLengthSquared",
          "type": "integer",
          "formula": "=IF(AND(NOT({{IsHypotenuse}}), {{IsTriangle}}), {{LengthSquared}})"
        },
        {
          "name": "PreviousSideLength",
          "type": "integer",
          "formula": "=INDEX(Sides!{{Length}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
        },
        {
          "name": "NextLength",
          "type": "integer",
          "formula": "=INDEX(Sides!{{Length}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
        },
        {
          "name": "PreviousAngle",
          "type": "integer",
          "formula": "=INDEX(Sides!{{Angle}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
        },
        {
          "name": "NextAngle",
          "type": "integer",
          "formula": "=INDEX(Sides!{{Angle}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
        },
        {
          "name": "PreviousLabel",
          "type": "string",
          "formula": "=INDEX(Sides!{{Label}}, MATCH(Sides!{{PreviousSide}}, Sides!{{SideId}}, 0))"
        },
        {
          "name": "NextLabel",
          "type": "string",
          "formula": "=INDEX(Sides!{{Label}}, MATCH(Sides!{{NextSide}}, Sides!{{SideId}}, 0))"
        }
      ]
    },
