        },
        {
          "name": "EmailAddress_from_Appuser",
          "type": "string",
          "formula": "=INDEX(AppUsers!{{EmailAddress}}, MATCH(Widgets!{{Appuser}}, AppUsers!{{AppUserId}}, 0))"
        },
        {
          "name": "Role_from_Appuser",
          "type": "string",
          "formula": "=INDEX(AppUsers!{{Role}}, MATCH(Widgets!{{Appuser}}, AppUsers!{{AppUserId}}, 0))"
        }
      ]
    }
