  "entities": {
    "Workflows": {
      "id_field": "WorkflowId",
      "id_field_snake": "workflow_id",
      "fields": {
        "WorkflowId": {
          "datatype": "string",
          "nullable": false,
          "type": "raw"
        },
        "Name": {
          "datatype": "string",
          "nullable": true,
          "type": "calculated",
          "description": "Short machine-friendly name for the workflow. Used for programmatic reference and URL slug generation."
        },
        "DisplayName": {
          "datatype": "string",
          "nullable": true,
          "type": "raw"
        },
        "Title": {
          "datatype": "string",
          "nullable": true,
          "type": "raw",
          "description": "Human-readable title of the workflow. Maps to dct:title from Dublin Core. Example: 'Production Deployment Workflow', 'Employee Onboarding'."
        },
        "Color": {
          "datatype": "string",
          "nullable": true,
          "type": "raw"
        },
        "Description": {
          "datatype": "string",
          "nullable": true,
          "type": "raw",
          "description": "Detailed description of the workflow's purpose and scope. Maps to dct:description from Dublin Core. Should explain what business goal the workflow achieves."
        },
        "Identifier": {
          "datatype": "string",
          "nullable": true,
          "type": "raw",
          "description": "External system identifier for cross-referencing. Maps to dct:identifier from Dublin Core. This is the join key back to document management systems, ticket systems, or other operational systems."
        },
        "Modified": {
          "datatype": "datetime",
          "nullable": true,
          "type": "raw",
          "description": "Last modification timestamp. Maps to dct:modified from Dublin Core. Critical for answering CQ5: 'Which workflows haven't been reviewed or updated in twelve months?'"
        },
        "WorkflowSteps": {
          "datatype": "string",
          "nullable": true,
          "type": "relationship",
          "description": "Reference to workflow steps. Represents the ntwf:hasStep relationship linking workflows to their constituent steps."
        },
        "CountOfNonProposedSteps": {
          "datatype": "integer",
          "nullable": true,
          "type": "aggregation",
          "description": "Calculated count of workflow steps in this workflow. Useful for workflow complexity analysis and reporting."
        },
        "HasMoreThan1Step": {
          "datatype": "boolean",
          "nullable": true,
          "type": "calculated"
        }
      },
      "calc_order": [
        "Name",
        "HasMoreThan1Step"
      ],
      "dep_edges": [
        [
          "CountOfNonProposedSteps",
          "HasMoreThan1Step"
        ],
        [
          "DisplayName",
          "Name"
        ]
      ],
      "expr_templates": {
        "Name": {
          "formula_source": "=SUBSTITUTE(LOWER({{DisplayName}}), \" \", \"-\")",
          "template_hash": "sha256:89d15a4a6be3f751",
          "root_node": "n_result_Name",
          "nodes": {
            "n_ref_1": {
              "kind": "field_ref",
              "field": "DisplayName",
              "field_snake": "display_name"
            },
            "n_fn_2": {
              "kind": "fn",
              "name": "LOWER",
              "args": [
                "n_ref_1"
              ]
            },
            "n_const_3": {
              "kind": "const",
              "value": " ",
              "type": "string"
            },
            "n_const_4": {
              "kind": "const",
              "value": "-",
              "type": "string"
            },
            "n_fn_5": {
              "kind": "fn",
              "name": "SUBSTITUTE",
              "args": [
                "n_fn_2",
                "n_const_3",
                "n_const_4"
              ]
            },
            "n_result_Name": {
              "kind": "result",
              "field": "Name",
              "field_snake": "name",
              "in": [
                "n_fn_5"
              ]
            }
          },
          "edges": [
