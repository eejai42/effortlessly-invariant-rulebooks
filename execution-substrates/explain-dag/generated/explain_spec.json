              "n_result_Name"
            ]
          ],
          "description": "Short machine-friendly name for the workflow. Used for programmatic reference and URL slug generation."
        },
        "HasMoreThan1Step": {
          "formula_source": "={{CountOfNonProposedSteps}} > 1",
          "template_hash": "sha256:52f3eecda8778602",
          "root_node": "n_result_HasMoreThan1Step",
          "nodes": {
            "n_ref_1": {
              "kind": "field_ref",
              "field": "CountOfNonProposedSteps",
              "field_snake": "count_of_non_proposed_steps"
            },
            "n_const_2": {
              "kind": "const",
              "value": 1,
              "type": "integer"
            },
            "n_op_3": {
              "kind": "op",
              "name": ">",
              "args": [
                "n_ref_1",
                "n_const_2"
              ]
            },
            "n_result_HasMoreThan1Step": {
              "kind": "result",
              "field": "HasMoreThan1Step",
              "field_snake": "has_more_than1_step",
              "in": [
