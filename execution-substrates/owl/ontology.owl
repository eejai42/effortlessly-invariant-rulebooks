@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

erb: a owl:Ontology ;
    rdfs:label "ERB Ontology" ;
    rdfs:comment "Generated from effortless-rulebook.json" .

# === Class: Customers ===
erb:Customers a owl:Class ;
    rdfs:label "Customers" ;
    rdfs:comment "Table: Customers" .

erb:customerId a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "CustomerId" .

erb:customer a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "Customer" ;
    rdfs:comment "Identifier for the customers." .

erb:emailAddress a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "EmailAddress" ;
    rdfs:comment "Thec ustomers email address" .

erb:firstName a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "FirstName" ;
    rdfs:comment "First Name of the customer - used to make the full name" .

erb:lastName a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "LastName" ;
    rdfs:comment "Last Name of the customer - used to make the full name" .

erb:fullName a owl:DatatypeProperty ;
    rdfs:domain erb:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "FullName" ;
    rdfs:comment "Full name is computed from the first and last name of the customer" .
    # calculated: calculated
