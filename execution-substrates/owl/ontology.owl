@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

erb: a owl:Ontology ;
    rdfs:label "ERB Ontology" ;
    rdfs:comment "Generated from effortless-rulebook.json" .

# === Class: AIAgents ===
erb:AIAgents a owl:Class ;
    rdfs:label "AIAgents" ;
    rdfs:comment "Table: AIAgents" .

erb:aIAgentId a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "AIAgentId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name of the AI agent. Maps to schema:name (not foaf:name, which is for persons)." .

erb:title a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Title" .

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:modelVersion a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "ModelVersion" ;
    rdfs:comment "Version string of the AI model. Maps to ntwf:modelVersion. Makes AI-produced artifacts auditable at the version level. The domain declaration means this property applies only to AIAgent individuals." .

erb:roles a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Roles" ;
    rdfs:comment "Back-reference to roles currently filled by this AI agent. Inverse of Roles.FilledBy_AIAgent." .

erb:workflowArtifacts a owl:DatatypeProperty ;
    rdfs:domain erb:AIAgents ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifacts" .

# === Class: Approvals ===
erb:Approvals a owl:Class ;
    rdfs:label "Approvals" ;
    rdfs:comment "Table: Approvals" .

erb:approvalId a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "ApprovalId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .
    # calculated: calculated

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:workflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowSteps" ;
    rdfs:comment "Back-reference to workflow steps that use this approval gate. Enables finding all steps requiring this specific gate." .

erb:escalationThresholdHours a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:integer ;
    rdfs:label "EscalationThresholdHours" ;
    rdfs:comment "Integer number of hours that may elapse on a pending gate before the ntwf:delegatesTo chain activates. Maps to ntwf:escalationThresholdHours. Domain applies only to ApprovalGate individuals." .

erb:workflow_from_WorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "Workflow_from_WorkflowSteps" .
    # calculated: lookup

erb:assigned_Role_from_WorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:string ;
    rdfs:label "Assigned_Role_from_WorkflowSteps" .
    # calculated: lookup

erb:sequence_Position_from_WorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:integer ;
    rdfs:label "Sequence_Position_from_WorkflowSteps" .
    # calculated: lookup

erb:requires_Human_Approval_from_WorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Approvals ;
    rdfs:range xsd:boolean ;
    rdfs:label "Requires_Human_Approval_from_WorkflowSteps" .
    # calculated: lookup

# === Class: AutomatedPipelines ===
erb:AutomatedPipelines a owl:Class ;
    rdfs:label "AutomatedPipelines" ;
    rdfs:comment "Table: AutomatedPipelines" .

erb:automatedPipelineId a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "AutomatedPipelineId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display name of the pipeline. Maps to schema:name (appropriate for software systems, unlike foaf:name which is for persons)." .

erb:description a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "Description" .

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:roles a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "Roles" ;
    rdfs:comment "Back-reference to roles currently filled by this pipeline. Inverse of Roles.FilledBy_AutomatedPipeline." .

erb:workflowArtifacts a owl:DatatypeProperty ;
    rdfs:domain erb:AutomatedPipelines ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifacts" .

# === Class: Departments ===
erb:Departments a owl:Class ;
    rdfs:label "Departments" ;
    rdfs:comment "Table: Departments" .

erb:departmentId a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "DepartmentId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Human-readable display name of the department. Should match organizational terminology for stakeholder communication." .
    # calculated: calculated

erb:title a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable display name of the department. Should match organizational terminology for stakeholder communication." .

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" ;
    rdfs:comment "Machine-friendly name for programmatic reference." .

erb:roles a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "Roles" ;
    rdfs:comment "Back-reference to roles owned by this department. Inverse of Roles.OwnedBy." .

erb:all_Owned_Roles a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "All_Owned_Roles" .
    # calculated: lookup

erb:all_Related_Workflow_Steps a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "All_Related_Workflow_Steps" .
    # calculated: lookup

erb:all_Distinct_Workflows_for_Owned_Roles a owl:DatatypeProperty ;
    rdfs:domain erb:Departments ;
    rdfs:range xsd:string ;
    rdfs:label "All_Distinct_Workflows_for_Owned_Roles" .
    # calculated: lookup

# === Class: ERBCustomizations ===
erb:ERBCustomizations a owl:Class ;
    rdfs:label "ERBCustomizations" ;
    rdfs:comment "Table: ERBCustomizations" .

erb:eRBCustomizationId a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "ERBCustomizationId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

erb:title a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "Title" .

erb:sQLCode a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "SQLCode" .

erb:sQLTarget a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "SQLTarget" .

erb:customizationType a owl:DatatypeProperty ;
    rdfs:domain erb:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "CustomizationType" .

# === Class: ERBVersions ===
erb:ERBVersions a owl:Class ;
    rdfs:label "ERBVersions" ;
    rdfs:comment "Table: ERBVersions" .

erb:eRBVersionId a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "ERBVersionId" .

erb:baseId a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "BaseId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

erb:message a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "Message" .

erb:notes a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "Notes" .

erb:commitDate a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "CommitDate" .

erb:isPublished a owl:DatatypeProperty ;
    rdfs:domain erb:ERBVersions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsPublished" .

# === Class: HumanAgents ===
erb:HumanAgents a owl:Class ;
    rdfs:label "HumanAgents" ;
    rdfs:comment "Table: HumanAgents" .

erb:humanAgentId a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "HumanAgentId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Full name of the person. Maps to foaf:name. Note: FOAF's name property is appropriate for persons, not for software systems (which use schema:name)." .

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:mbox a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Mbox" ;
    rdfs:comment "Email address of the person. Maps to foaf:mbox. Used for notifications and organizational directory integration." .

erb:roles a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Roles" ;
    rdfs:comment "Back-reference to roles currently filled by this agent. Inverse of Roles.FilledBy_HumanAgent." .

erb:all_Linked_Roles a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "All_Linked_Roles" .
    # calculated: lookup

erb:all_Related_Workflow_Steps a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "All_Related_Workflow_Steps" .
    # calculated: lookup

erb:all_Distinct_Workflows_for_Linked_Roles a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "All_Distinct_Workflows_for_Linked_Roles" .
    # calculated: lookup

erb:workflowArtifacts a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifacts" .

# === Class: PrecedesSteps ===
erb:PrecedesSteps a owl:Class ;
    rdfs:label "PrecedesSteps" ;
    rdfs:comment "Table: PrecedesSteps" .

erb:precedesStepId a owl:DatatypeProperty ;
    rdfs:domain erb:PrecedesSteps ;
    rdfs:range xsd:string ;
    rdfs:label "PrecedesStepId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:PrecedesSteps ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Ordinal sequence number for the relationship. Used for sorting and display." .

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:PrecedesSteps ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .
    # calculated: calculated

erb:stepNumber a owl:DatatypeProperty ;
    rdfs:domain erb:PrecedesSteps ;
    rdfs:range xsd:integer ;
    rdfs:label "StepNumber" .

erb:workflowStep a owl:DatatypeProperty ;
    rdfs:domain erb:PrecedesSteps ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowStep" ;
    rdfs:comment "Foreign key to the step that comes BEFORE. The source of the 'precedes' relationship." .

# === Class: Roles ===
erb:Roles a owl:Class ;
    rdfs:label "Roles" ;
    rdfs:comment "Table: Roles" .

erb:roleId a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "RoleId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .
    # calculated: calculated

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:label a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Label" ;
    rdfs:comment "Human-readable display name. Maps to rdfs:label. Per Heuristic 6: if you cannot write a clear label, you do not yet understand the concept well enough to model it." .

erb:comment a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Comment" ;
    rdfs:comment "Detailed description of the role's responsibilities and scope. Maps to rdfs:comment. Should define what the role covers, what it excludes, and how it differs from adjacent roles." .

erb:filledByHumanAgent a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledByHumanAgent" .

erb:filledByAIAgent a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledByAIAgent" .

erb:filledByAutomatedPipeline a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledByAutomatedPipeline" .

erb:ownedBy a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "OwnedBy" ;
    rdfs:comment "Foreign key to the Department that owns this role. Maps to ntwf:ownedBy (owl:FunctionalProperty). Enables answering CQ7: 'Which workflows involve both Engineering and Legal?'" .

erb:delegatesTo a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "DelegatesTo" ;
    rdfs:comment "Foreign key to the fallback Role in an escalation chain. Maps to ntwf:delegatesTo. Enables answering CQ6: 'What happens when the VP of Engineering is unavailable?'" .

erb:workflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowSteps" ;
    rdfs:comment "Back-reference to workflow steps assigned to this role. Inverse of WorkflowSteps.AssignedRole." .

erb:fromDelegatesTo a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FromDelegatesTo" .

erb:all_Linked_Workflow_Steps a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "All_Linked_Workflow_Steps" .
    # calculated: lookup

erb:distinct_Workflows_for_Linked_Steps a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Distinct_Workflows_for_Linked_Steps" .
    # calculated: lookup

erb:workflowArtifacts a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifacts" .

# === Class: StepTransitions ===
erb:StepTransitions a owl:Class ;
    rdfs:label "StepTransitions" ;
    rdfs:comment "Table: StepTransitions" .

erb:stepTransitionId a owl:DatatypeProperty ;
    rdfs:domain erb:StepTransitions ;
    rdfs:range xsd:string ;
    rdfs:label "StepTransitionId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:StepTransitions ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

erb:from_Step a owl:DatatypeProperty ;
    rdfs:domain erb:StepTransitions ;
    rdfs:range xsd:string ;
    rdfs:label "From_Step" .

erb:to_Step a owl:DatatypeProperty ;
    rdfs:domain erb:StepTransitions ;
    rdfs:range xsd:string ;
    rdfs:label "To_Step" .

erb:workflow_from_From_Step a owl:DatatypeProperty ;
    rdfs:domain erb:StepTransitions ;
    rdfs:range xsd:string ;
    rdfs:label "Workflow_from_From_Step" .
    # calculated: lookup

# === Class: WorkflowArtifacts ===
erb:WorkflowArtifacts a owl:Class ;
    rdfs:label "WorkflowArtifacts" ;
    rdfs:comment "Table: WorkflowArtifacts" .

erb:workflowArtifactId a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifactId" .

erb:artifact_Name a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Artifact_Name" .

erb:produced_By_Step a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Produced_By_Step" .

erb:workflow_from_Produced_By_Step a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Workflow_from_Produced_By_Step" .
    # calculated: lookup

erb:attributed_Role a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Attributed_Role" .

erb:attributed_Human_Agent a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Attributed_Human_Agent" .

erb:attributed_AI_Agent a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Attributed_AI_Agent" .

erb:attributed_Pipeline a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Attributed_Pipeline" .

erb:derived_From_Artifact a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Derived_From_Artifact" .

erb:artifact_Description a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Artifact_Description" .

erb:artifact_File a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "Artifact_File" .

erb:from_field_Derived_From_Artifact a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowArtifacts ;
    rdfs:range xsd:string ;
    rdfs:label "From_field_Derived_From_Artifact" .

# === Class: WorkflowSteps ===
erb:WorkflowSteps a owl:Class ;
    rdfs:label "WorkflowSteps" ;
    rdfs:comment "Table: WorkflowSteps" .

erb:workflowStepId a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowStepId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .
    # calculated: calculated

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:workflow a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "Workflow" ;
    rdfs:comment "Foreign key to the parent workflow. Represents the inverse of ntwf:hasStep, enabling navigation from step to its containing workflow (ntwf:isStepOf)." .

erb:sequencePosition a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:integer ;
    rdfs:label "SequencePosition" ;
    rdfs:comment "Integer ordinal position of the step within its workflow. Maps to ntwf:sequencePosition, declared as owl:FunctionalProperty (each step has exactly one position). Enables positional queries." .

erb:assignedRole a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRole" ;
    rdfs:comment "Foreign key to the Role responsible for executing this step. Maps to ntwf:assignedRole. Critical for implementing Heuristic 2 (role-agent separation): steps point to roles, not directly to agents." .

erb:requiresHumanApproval a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:boolean ;
    rdfs:label "RequiresHumanApproval" ;
    rdfs:comment "Boolean flag indicating whether a human agent must fill the assigned role. Maps to ntwf:requiresHumanApproval. Enables answering CQ3: 'Which steps require human decisions vs. AI execution?'" .

erb:approvalGate a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "ApprovalGate" ;
    rdfs:comment "Foreign key to ApprovalGate if this step is a decision checkpoint. When populated, indicates this step blocks workflow execution until explicit authorization is given." .

erb:precededBySteps a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "PrecededBySteps" ;
    rdfs:comment "Reference to steps that must complete before this step can execute. Part of the ntwf:precedesStep transitive ordering relationship." .

erb:executionActorType a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "ExecutionActorType" .
    # calculated: calculated

erb:assignedRoleDepartment a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRoleDepartment" .
    # calculated: lookup

erb:approvalGateEscalationThresholdHours a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:integer ;
    rdfs:label "ApprovalGateEscalationThresholdHours" .
    # calculated: lookup

erb:stepTransitions_From_Step a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "StepTransitions_From_Step" .

erb:stepTransitions_To_Step a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "StepTransitions_To_Step" .

erb:workflowArtifacts a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowArtifacts" .

# === Class: Workflows ===
erb:Workflows a owl:Class ;
    rdfs:label "Workflows" ;
    rdfs:comment "Table: Workflows" .

erb:workflowId a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Short machine-friendly name for the workflow. Used for programmatic reference and URL slug generation." .
    # calculated: calculated

erb:displayName a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "DisplayName" .

erb:title a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable title of the workflow. Maps to dct:title from Dublin Core. Example: 'Production Deployment Workflow', 'Employee Onboarding'." .

erb:description a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "Detailed description of the workflow's purpose and scope. Maps to dct:description from Dublin Core. Should explain what business goal the workflow achieves." .

erb:identifier a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Identifier" ;
    rdfs:comment "External system identifier for cross-referencing. Maps to dct:identifier from Dublin Core. This is the join key back to document management systems, ticket systems, or other operational systems." .

erb:modified a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Modified" ;
    rdfs:comment "Last modification timestamp. Maps to dct:modified from Dublin Core. Critical for answering CQ5: 'Which workflows haven't been reviewed or updated in twelve months?'" .

erb:workflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowSteps" ;
    rdfs:comment "Reference to workflow steps. Represents the ntwf:hasStep relationship linking workflows to their constituent steps." .

erb:countOfSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfSteps" ;
    rdfs:comment "Calculated count of workflow steps in this workflow. Useful for workflow complexity analysis and reporting." .
    # calculated: aggregation

erb:hasMoreThan1Step a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:boolean ;
    rdfs:label "HasMoreThan1Step" .
    # calculated: calculated
