@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

erb: a owl:Ontology ;
    rdfs:label "ERB Ontology" ;
    rdfs:comment "Generated from effortless-rulebook.json" .

# === Class: HumanAgents ===
erb:HumanAgents a owl:Class ;
    rdfs:label "HumanAgents" ;
    rdfs:comment "Table: HumanAgents" .

erb:humanAgentId a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "HumanAgentId" .

erb:name a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

erb:mbox a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Mbox" .

erb:roles a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:string ;
    rdfs:label "Roles" .

erb:countOfRles a owl:DatatypeProperty ;
    rdfs:domain erb:HumanAgents ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfRles" .
    # calculated: aggregation

# === Class: Roles ===
erb:Roles a owl:Class ;
    rdfs:label "Roles" ;
    rdfs:comment "Table: Roles" .

erb:roleId a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "RoleId" .

erb:label a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Label" .

erb:comment a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "Comment" .

erb:filledBy a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledBy" .

erb:workflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowSteps" .

erb:countOfWorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfWorkflowSteps" .
    # calculated: aggregation

erb:filledByName a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledByName" .
    # calculated: lookup

erb:filledByMBox a owl:DatatypeProperty ;
    rdfs:domain erb:Roles ;
    rdfs:range xsd:string ;
    rdfs:label "FilledByMBox" .
    # calculated: lookup

# === Class: WorkflowSteps ===
erb:WorkflowSteps a owl:Class ;
    rdfs:label "WorkflowSteps" ;
    rdfs:comment "Table: WorkflowSteps" .

erb:workflowStepId a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowStepId" .

erb:label a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "Label" .

erb:sequencePosition a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:integer ;
    rdfs:label "SequencePosition" .

erb:requiresHumanApproval a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:boolean ;
    rdfs:label "RequiresHumanApproval" .

erb:isStepOf a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "IsStepOf" .

erb:assignedRole a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRole" .

erb:isStepOfTitle a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "IsStepOfTitle" .
    # calculated: lookup

erb:isStepOfDescription a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "IsStepOfDescription" .
    # calculated: lookup

erb:isStepOfIdentifier a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "IsStepOfIdentifier" .
    # calculated: lookup

erb:assignedRoleLabel a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRoleLabel" .
    # calculated: lookup

erb:assignedRoleComment a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRoleComment" .
    # calculated: lookup

erb:assignedRoleFilledBy a owl:DatatypeProperty ;
    rdfs:domain erb:WorkflowSteps ;
    rdfs:range xsd:string ;
    rdfs:label "AssignedRoleFilledBy" .
    # calculated: lookup

# === Class: Workflows ===
erb:Workflows a owl:Class ;
    rdfs:label "Workflows" ;
    rdfs:comment "Table: Workflows" .

erb:workflowId a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowId" .

erb:title a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Title" .

erb:description a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Description" .

erb:created a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Created" .

erb:modified a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Modified" .

erb:identifier a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "Identifier" .

erb:workflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:string ;
    rdfs:label "WorkflowSteps" .

erb:countOfWorkflowSteps a owl:DatatypeProperty ;
    rdfs:domain erb:Workflows ;
    rdfs:range xsd:integer ;
    rdfs:label "CountOfWorkflowSteps" .
    # calculated: aggregation
