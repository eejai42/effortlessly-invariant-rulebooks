@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

# === Shape with rules for Approvals ===
erb:ApprovalsShape a sh:NodeShape ;
    sh:targetClass erb:Approvals ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Approvals_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:Approvals .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] .
# Rule for Workflow_from_WorkflowSteps - parse error: Unexpected character '!' at position 19
