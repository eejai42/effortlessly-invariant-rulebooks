# === Shape with rules for PrecedesSteps ===
erb:PrecedesStepsShape a sh:NodeShape ;
    sh:targetClass erb:PrecedesSteps ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PrecedesSteps_DisplayName" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:displayName ?_result .
            }
            WHERE {
    $this a erb:PrecedesSteps .
    OPTIONAL { $this erb:stepNumber ?step_number . }
                BIND(CONCAT("Step-", ?step_number) AS ?_result)
            }
        """ ;
    ] .

