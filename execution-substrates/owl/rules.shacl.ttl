@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

# === Shape with rules for ApprovalGates ===
erb:ApprovalGatesShape a sh:NodeShape ;
    sh:targetClass erb:ApprovalGates ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Departments ===
erb:DepartmentsShape a sh:NodeShape ;
    sh:targetClass erb:Departments ;
    sh:rule [
